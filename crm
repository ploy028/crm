        function updateCustomerStats() {
            const totalCustomers = customers.length;
            const vipCount = customers.filter(c => c.type === 'VIP').length;
            const regularCount = customers.filter(c => c.type === 'Regular').length;
            const newCount = customers.filter(c => c.type === 'New').length;
            const totalSales = customers.reduce((sum, c) => sum + c.sales, 0);
            
            // Update dashboard stats
            document.getElementById('totalCustomers').textContent = totalCustomers.toLocaleString();
            document.getElementById('monthlySales').textContent = `₿${Math.round(totalSales/1000)}K`;
            document.getElementById('newCustomers').textContent = newCount;
            document.getElementById('repeatCustomers').textContent = Math.round(vipCount * 0.8);
        }
        
        function filterCustomers() {
            const searchTerm = document.getElementById('customerSearch').value.toLowerCase();
            const filterType = document.getElementById('customerFilter').value;
            
            filteredCustomers = customers.filter(customer => {
                const matchesSearch = customer.name.toLowerCase().includes(searchTerm) ||
                                    customer.phone.includes(searchTerm) ||
                                    customer.email.toLowerCase().includes(searchTerm);
                const matchesType = !filterType || customer.type === filterType;
                
                return matchesSearch && matchesType;
            });
            
            renderCustomerTable();
        }
        
        function sortCustomers(field) {
            if (currentSort.field === field) {
                currentSort.direction = currentSort.direction === 'asc' ? 'desc' : 'asc';
            } else {
                currentSort.field = field;
                currentSort.direction = 'asc';
            }
            
            filteredCustomers.sort((a, b) => {
                let aVal = a[field];
                let bVal = b[field];
                
                if (field === 'sales') {
                    aVal = parseFloat(aVal);
                    bVal = parseFloat(bVal);
                } else if (typeof aVal === 'string') {
                    aVal = aVal.toLowerCase();
                    bVal = bVal.toLowerCase();
                }
                
                if (currentSort.direction === 'asc') {
                    return aVal > bVal ? 1 : -1;
                } else {
                    return aVal < bVal ? 1 : -1;
                }
            });
            
            renderCustomerTable();
        }

