        function calculateReceiptItemTotal(input) {
            const row = input.closest('tr');
            const quantity = parseFloat(row.querySelector('.receipt-item-quantity').value) || 0;
            const price = parseFloat(row.querySelector('.receipt-item-price').value) || 0;
            const total = quantity * price;
            
            row.querySelector('.receipt-item-total').textContent = `₿${total.toLocaleString()}`;
            calculateReceiptTotal();
        }

        function calculateReceiptTotal() {
            const rows = document.querySelectorAll('#receiptItemsBody tr');
            let subtotal = 0;
            
            rows.forEach(row => {
                const quantity = parseFloat(row.querySelector('.receipt-item-quantity').value) || 0;
                const price = parseFloat(row.querySelector('.receipt-item-price').value) || 0;
                subtotal += quantity * price;
            });
            
            const discount = parseFloat(document.getElementById('receiptDiscount').value) || 0;
            const discountAmount = subtotal * (discount / 100);
            const afterDiscount = subtotal - discountAmount;
            const vat = afterDiscount * 0.07;
            const grandTotal = afterDiscount + vat;
            
            document.getElementById('receiptSubtotal').textContent = `₿${afterDiscount.toLocaleString()}`;
            document.getElementById('receiptVat').textContent = `₿${vat.toLocaleString()}`;
            document.getElementById('receiptGrandTotal').textContent = `₿${grandTotal.toLocaleString()}`;
            
            calculateChange();
        }

        function calculateChange() {
            const grandTotalText = document.getElementById('receiptGrandTotal').textContent;
            const grandTotal = parseFloat(grandTotalText.replace('₿', '').replace(/,/g, '')) || 0;
            const amountReceived = parseFloat(document.getElementById('receiptAmountReceived').value) || 0;
            const change = amountReceived - grandTotal;
            
            document.getElementById('receiptChange').textContent = `₿${change >= 0 ? change.toLocaleString() : '0'}`;
            
            if (change < 0 && amountReceived > 0) {
                document.getElementById('receiptChange').style.color = '#ef4444';
                document.getElementById('receiptChange').textContent = `₿${Math.abs(change).toLocaleString()} (ขาด)`;
            } else {
                document.getElementById('receiptChange').style.color = '#2563eb';
            }
        }

