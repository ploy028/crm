                row.innerHTML = `
                    <td class="px-6 py-4"><input type="checkbox" class="rounded customer-checkbox" data-id="${customer.id}"></td>
                    <td class="px-6 py-4 font-medium">${customer.name}</td>
                    <td class="px-6 py-4">${customer.phone}</td>
                    <td class="px-6 py-4">${customer.email}</td>
                    <td class="px-6 py-4"><span class="${typeClass} px-2 py-1 rounded-full text-sm">${customer.type}</span></td>
