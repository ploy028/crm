        function calculateProposalTotal() {
            const rows = document.querySelectorAll('#proposalItemsBody tr');
            let subtotal = 0;
            
            rows.forEach(row => {
                const quantity = parseFloat(row.querySelector('.item-quantity').value) || 0;
                const price = parseFloat(row.querySelector('.item-price').value) || 0;
                subtotal += quantity * price;
            });
            
            const discount = parseFloat(document.getElementById('proposalDiscount').value) || 0;
            const discountAmount = subtotal * (discount / 100);
            const afterDiscount = subtotal - discountAmount;
            const vat = afterDiscount * 0.07;
            const grandTotal = afterDiscount + vat;
            
            document.getElementById('proposalVat').textContent = `₿${vat.toLocaleString()}`;
            document.getElementById('proposalGrandTotal').textContent = `₿${grandTotal.toLocaleString()}`;
        }

