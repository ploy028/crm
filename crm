        function calculateInvoiceTotal() {
            const rows = document.querySelectorAll('#invoiceItemsBody tr');
            let subtotal = 0;
            
            rows.forEach(row => {
                const quantity = parseFloat(row.querySelector('.invoice-item-quantity').value) || 0;
                const price = parseFloat(row.querySelector('.invoice-item-price').value) || 0;
                subtotal += quantity * price;
            });
            
            const discount = parseFloat(document.getElementById('invoiceDiscount').value) || 0;
            const discountAmount = subtotal * (discount / 100);
            const afterDiscount = subtotal - discountAmount;
            const vat = afterDiscount * 0.07;
            const grandTotal = afterDiscount + vat;
            
            document.getElementById('invoiceSubtotal').textContent = `₿${afterDiscount.toLocaleString()}`;
            document.getElementById('invoiceVat').textContent = `₿${vat.toLocaleString()}`;
            document.getElementById('invoiceGrandTotal').textContent = `₿${grandTotal.toLocaleString()}`;
        }

